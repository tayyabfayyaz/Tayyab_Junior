# ============================================
# FTE – Fully Task Executor Environment Config
# ============================================
# Copy this file to .env and fill in your values

# --- Core ---
FTE_ENV=development
TASK_DIR=./tasks
MEMORY_DIR=./memory
LOG_DIR=./logs

# --- Auth ---
JWT_SECRET=change-me-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD_HASH=

# --- Claude / Anthropic ---
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- Executor ---
EXECUTOR_POLL_INTERVAL_SECONDS=5
EXECUTOR_MAX_RETRIES=3
MCP_SERVER_URL=http://mcp-server:8001

# --- WhatsApp Business API ---
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_ACCESS_TOKEN=your-meta-access-token
WHATSAPP_PHONE_ID=your-phone-number-id
WHATSAPP_OWNER_PHONE=your-phone-number

# --- Gmail ---
GMAIL_CLIENT_ID=your-google-client-id
GMAIL_CLIENT_SECRET=your-google-client-secret
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gmail-push
GMAIL_MONITORED_EMAIL=your-email@gmail.com

# --- LinkedIn ---
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token

# --- Twitter / X ---
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret

# --- GitHub ---
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# --- CEO Assistant ---
CEO_EMAIL=ceo@example.com
REPORT_TIME=18:00
REPORTS_DIR=./reports

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
